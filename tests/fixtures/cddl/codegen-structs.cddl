; Test fixture for codegen integration tests

person = {
  name: tstr,
  age: uint,
  ? email: tstr,
}

address = {
  street: tstr,
  city: tstr,
  zip-code: tstr,
  ? state: tstr,
}

contact = {
  person: person,
  home-address: address,
  ? phone: tstr,
}

status = "active" / "inactive" / "pending"

measurement = {
  value: float64,
  unit: tstr,
  ? precision: float,
  ? timestamp: uint,
}

name = tstr

ids = [* uint]

payload = {
  type: tstr,
  data: bstr,
  ? metadata: { * tstr => any },
}

response = {
  code: uint,
  body: tstr / null,
}
